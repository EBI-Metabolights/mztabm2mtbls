{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
        // "--input-file=test/data/MTBLS263/mztabm/MTBLS263.mztab"
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run converter",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mztabm2mtbls/converter.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--input-file=test/data/test2/LCS-00001-1.mztabm"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Validate Local Study",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mztabm2mtbls/commands/validate_study.py",
      "args": [
        "--mtbls_provisional_study_id=MTBLS263",
        "--mztabm_file_path=test/data/LCS-00001-1/LCS-00001-1.mztabm",
        "--data_files_path=test/data/LCS-00001-1/files",
        "--target_metadata_files_path=test/data/LCS-00001-1/mztab",
        "--opa_executable_path=opa",
        "--mtbls_validation_bundle_path=${workspaceFolder}/bundle.tar.gz",
        "--mtbls_validation_wasm_path=${workspaceFolder}/mtbls-validation.wasm",
        "--config_file=test/data/configurations/mztabm2mtbls_config.json",
        "--temp_folder=output/temp",
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Run Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    }
  ]
}
