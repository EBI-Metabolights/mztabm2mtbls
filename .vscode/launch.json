{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
        // "--input-file=test/data/MTBLS263/mztabm/MTBLS263.mztab"
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run converter",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mztabm2mtbls/converter.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--input-file=test/data/test2/LCS-00001-1.mztabm"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Validate Local Study",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mztabm2mtbls/commands/convert_and_validate_submission.py",
      "args": [
        "--mtbls-provisional-study-id=MTBLS10000000",
        "--mztabm-file-path=test/data/LCS-00001-1/LCS-00001-1.mztabm",
        "--data-files-path=test/data/LCS-00001-1/files",
        "--target-metadata-files-path=test/data/LCS-00001-1/isa-tab",
        "--opa-executable-path=opa",
        "--mtbls-validation-bundle-path=${workspaceFolder}/bundle.tar.gz",
        "--mtbls-validation-wasm-path=${workspaceFolder}/mtbls-validation.wasm",
        "--config-file=test/data/configurations/mztabm2mtbls_config.json",
        "--temp-folder=output/temp",
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Run Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    }
  ]
}
